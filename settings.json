      {
        "hooks": [
          {
            "type": "command",
            "command": "say -r 200 '全てのタスクが完了しました'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "say -r 200 '確認が必要です'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
