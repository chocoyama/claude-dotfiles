{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(/Users/chocoyama/.claude/skills/tree-pr/scripts/list-my-prs.sh:*)",
      "Bash(/Users/chocoyama/.claude/skills/tree-pr/scripts/list-review-requested-prs.sh:*)",
      "Bash(/Users/chocoyama/.claude/skills/tree-pr/scripts/list-my-merged-prs.sh:*)",
      "Bash(gh api user *:*)",
      "READ(*.md:*)",
      "mcp__serena__search_for_pattern",
      "mcp__serena__find_symbol",
      "mcp__serena__list_dir",
      "mcp__figma-desktop__get_design_context",
      "mcp__figma-desktop__get_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__knowledge-server__get_file_content",
